{
  "name": "eqoa-data",
  "version": "2.2.11",
  "description": "JSON file data for EQOA information such as guides/quests listed on Jadiction.com",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "images"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./images/*": "./images/*"
  },
  "scripts": {
    "generate:contributors": "node --experimental-strip-types scripts/generate-contributors.ts",
    "generate:data": "node --experimental-strip-types scripts/generate-json-exports.ts",
    "generate:images": "node --experimental-strip-types scripts/generate-images-export.ts",
    "build": "npm run generate:data && npm run generate:images && tsup",
    "build:release": "npm run generate:contributors && npm run build",
    "prepack": "npm run build",
    "dev": "tsup --watch src/index.ts --format esm",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "everquest",
    "everquest online adventures",
    "everquest online adventures frontiers",
    "eqoa",
    "eqoa data",
    "eqoa guides",
    "eqoa quests",
    "eq data",
    "eq guides",
    "eq quests"
  ],
  "homepage": "https://github.com/Jadiction/EQOA-Data#readme",
  "bugs": {
    "url": "https://github.com/Jadiction/EQOA-Data/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jadiction/EQOA-Data.git"
  },
  "license": "ISC",
  "author": "Jad",
  "engines": {
    "node": ">=22.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
